@baseUrl = http://localhost:3000/api/user

###
POST {{baseUrl}}/register
Content-Type: application/json

{
    "email": "alvaro@ejemplo.com",
    "password": "SuperPassword123",
    "name": "Alvaro",
    "lastName": "Naval",
    "nif": "12345678A"
}

###
POST {{baseUrl}}/login
Content-Type: application/json

{
    "email": "alvaro@ejemplo.com",
    "password": "SuperPassword123"
}

### Obtener mi usuario (Ruta protegida)
GET {{baseUrl}}/
Authorization: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJfaWQiOiI2OWQxODM1OGY4YjQwMzQxY2VhMjY2MDQiLCJyb2xlIjoiYWRtaW4iLCJpYXQiOjE3NzUzMzg2MjUsImV4cCI6MTc3NTMzOTUyNX0.RcAdl2K1FfmjIlBxYa2sIWCb5pyvxMuFzQOJn-AkoRU

### Verificar Email
PUT {{baseUrl}}/validation
