@baseUrl = http://localhost:3000/api/user
@authToken = PEGA_AQUI_TU_ACCESS_TOKEN
@refreshToken = PEGA_AQUI_TU_REFRESH_TOKEN

### 1. Registro
POST {{baseUrl}}/register
Content-Type: application/json

{
    "email": "alvaro@utad.com",
    "password": "Password123",
    "name": "Alvaro",
    "lastName": "Naval",
    "nif": "12345678A"
}

### 2. Login
POST {{baseUrl}}/login
Content-Type: application/json

{
    "email": "alvaro@utad.com",
    "password": "Password123"
}

### 3. Obtener mi usuario (Ruta protegida)
GET {{baseUrl}}/
Authorization: Bearer {{authToken}}

### 4. Verificar Email
PUT {{baseUrl}}/validation
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
    "code": "AQUI_EL_CODIGO_DE_TU_BASE_DE_DATOS"
}

### 5. Actualizar Datos Personales (Onboarding)
PUT {{baseUrl}}/register
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
    "name": "Alvaro Modificado",
    "lastName": "Naval Lopez",
    "nif": "87654321Z"
}

### 6. Crear Compañía (Onboarding Autónomo - Bonus Zod)
PATCH {{baseUrl}}/company
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
    "isFreelance": true
}

### 7. Subir Logo de Compañía (multipart/form-data)
PATCH {{baseUrl}}/logo
Authorization: Bearer {{authToken}}
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="logo"; filename="milogo.png"
Content-Type: image/png

< ./ruta_a_una_imagen_de_prueba.png
------WebKitFormBoundary7MA4YWxkTrZu0gW--

### 8. Cambiar Contraseña (Bonus Zod .refine)
PUT {{baseUrl}}/password
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
    "currentPassword": "Password123",
    "newPassword": "NuevaPassword456"
}

### 9. Invitar a un compañero (Solo Admin)
POST {{baseUrl}}/invite
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
    "email": "invitado@ejemplo.com",
    "password": "InvitadoPassword123",
    "name": "Compañero",
    "lastName": "De Obra",
    "nif": "99999999X"
}

### 10. Refrescar sesión
POST {{baseUrl}}/refresh
Content-Type: application/json

{
    "refreshToken": "{{refreshToken}}"
}

### 11. Cerrar Sesión (Logout)
POST {{baseUrl}}/logout
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
    "refreshToken": "{{refreshToken}}"
}

### 12. Eliminar Usuario (Soft Delete)
DELETE {{baseUrl}}/?soft=true
Authorization: Bearer {{authToken}}

###########################################################
# ENDPOINTS DE CLIENTES
# Requiere: estar logueado + tener compañía creada
###########################################################

@clientUrl = http://localhost:3000/api/client
@clientId = PEGA_AQUI_EL_ID_DEL_CLIENTE

### 13. Crear un cliente
POST {{clientUrl}}
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
    "name": "Construcciones García S.L.",
    "cif": "B12345678",
    "email": "info@garcia.com",
    "phone": "912345678",
    "address": {
        "street": "Calle Mayor",
        "number": "10",
        "postal": "28001",
        "city": "Madrid",
        "province": "Madrid"
    }
}

### 14. Listar clientes (con paginación)
GET {{clientUrl}}?page=1&limit=10
Authorization: Bearer {{authToken}}

### 15. Listar clientes (con filtro por nombre)
GET {{clientUrl}}?name=García&sort=-createdAt
Authorization: Bearer {{authToken}}

### 16. Obtener un cliente concreto
GET {{clientUrl}}/{{clientId}}
Authorization: Bearer {{authToken}}

### 17. Actualizar un cliente
PUT {{clientUrl}}/{{clientId}}
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
    "name": "Construcciones García Renovada S.L.",
    "phone": "912345679"
}

### 18. Archivar un cliente (soft delete)
DELETE {{clientUrl}}/{{clientId}}?soft=true
Authorization: Bearer {{authToken}}

### 19. Listar clientes archivados
GET {{clientUrl}}/archived
Authorization: Bearer {{authToken}}

### 20. Restaurar un cliente archivado
PATCH {{clientUrl}}/{{clientId}}/restore
Authorization: Bearer {{authToken}}

### 21. Eliminar un cliente permanentemente (hard delete)
DELETE {{clientUrl}}/{{clientId}}
Authorization: Bearer {{authToken}}