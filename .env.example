PORT=PON_AQUI_TU_PUERTO
# Conexión a Base de Datos (Sustituir usuario, password, cluster y bbdd)
DB_URI=mongodb+srv://<tu_usuario>:<tu_password>@<tu_cluster>.mongodb.net/<nombre_base_datos>?retryWrites=true&w=majority
# Alternativa directa, tuve problemas para conectarme a mi base de datos con el de arriba me daba refused
# DB_URI=mongodb://<tu_usuario>:<tu_password>@<shard-00>,<shard-01>,<shard-02>/<nombre_base_datos>?ssl=true&replicaSet=<replica>&authSource=admin&retryWrites=true&w=majority

JWT_SECRET=tu_clave_secreta_super_segura_aqui

#Practica 2
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion
SMTP_FROM=BildyApp <tu_email@gmail.com>

# Slack (Logging de errores 5XX)
SLACK_WEBHOOK=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ